{
  "icons": {
    "16": "./gen-assets/icon16.plasmo.png",
    "32": "./gen-assets/icon32.plasmo.png",
    "48": "./gen-assets/icon48.plasmo.png",
    "64": "./gen-assets/icon64.plasmo.png",
    "128": "./gen-assets/icon128.plasmo.png"
  },
  "manifest_version": 3,
  "action": {
    "default_icon": {
      "16": "./gen-assets/icon16.plasmo.png",
      "32": "./gen-assets/icon32.plasmo.png",
      "48": "./gen-assets/icon48.plasmo.png",
      "64": "./gen-assets/icon64.plasmo.png",
      "128": "./gen-assets/icon128.plasmo.png"
    },
    "default_popup": "./popup.html"
  },
  "version": "1.0.0",
  "name": "Mote LAB - Marketplace Research",
  "description": "Riset produk Shopee & Tokopedia secara otomatis",
  "background": {
    "service_worker": "./static/background/index.ts"
  },
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://lab.motekreatif.com/*",
        "http://localhost:3003/*"
      ],
      "js": [
        "../contents/auth.ts"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://shopee.co.id/*"
      ],
      "js": [
        "static/contents/shopee.tsx"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.tokopedia.com/*",
        "https://tokopedia.com/*"
      ],
      "js": [
        "static/contents/tokopedia.tsx"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://shopee.co.id/*",
    "https://www.tokopedia.com/*",
    "https://tokopedia.com/*",
    "https://lab.motekreatif.com/*",
    "http://localhost:3003/*"
  ]
}
