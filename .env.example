# ================================================
# MOTE LAB — Environment Variables
# Copy to .env.local (local) or configure in Easypanel
# ================================================

# Server
NODE_ENV=development
PORT=3003
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Database (PostgreSQL 16)
# Easypanel: postgres://motelab:PASSWORD@mote_mote-lab-db:5432/motelab?sslmode=disable
DATABASE_URL=postgres://motelab:changeme@localhost:5432/motelab?sslmode=disable

# Redis 7
# Easypanel: redis://default:PASSWORD@mote_mote-lab-redis:6379
REDIS_URL=redis://localhost:6379

# better-auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-32-char-random-string-here
BETTER_AUTH_URL=http://localhost:3003

# Google OAuth (reuse Mote Blaster credentials)
# Add redirect URI: https://lab.motekreatif.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Owner account
# OWNER_EMAIL must match the email used to login
OWNER_EMAIL=smnanan@motekreatif.com
# Generate hash: node scripts/hash-password.js "yourpassword"
OWNER_PASSWORD_HASH=$2b$10$changeme

# Plan configuration
TRIAL_DAYS=7
TRIAL_DAILY_LIMIT=100
STARTER_DAILY_LIMIT=500
PRO_DAILY_LIMIT=999999

# Extension rate limits
EXTENSION_API_RATE_LIMIT_PER_MIN=60

# Xendit (Phase 2 — leave empty for now)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_STARTER_PRICE=99000
XENDIT_PRO_PRICE=199000
XENDIT_LIFETIME_PRICE=1999000
